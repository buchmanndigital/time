# Neon (kostenlos): https://console.neon.tech — Region z. B. Frankfurt (eu-central-1)
DATABASE_URL=

# Zufallsstring (mind. 16 Zeichen), z. B. openssl rand -base64 32
AUTH_SECRET=

# Google AI Studio / Gemini: https://aistudio.google.com/apikey — nur serverseitig, nie ins Repo committen
GEMINI_API_KEY=
# Optional, Standard: gemini-2.5-flash
# GEMINI_MODEL=gemini-2.0-flash

# Web-Push (PWA): web-push generieren — npm run push:generate-keys
# VAPID_SUBJECT=mailto:du@example.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Cron /api/cron/task-push (Vercel Cron sendet Authorization: Bearer …)
# CRON_SECRET=

# Optional: Web-Recherche im KI-Assistenten (Browser Use Cloud / gleicher Key wie „browser-use cloud login“)
# https://cloud.browser-use.com/settings?tab=api-keys&new=1
# BROWSER_USE_API_KEY=bu_...
# Optional: bu-mini (Standard, günstiger) | bu-max | bu-ultra — https://docs.browser-use.com/cloud/quickstart
# BROWSER_USE_AGENT_MODEL=bu-mini
# Optional: Task-Wartezeit in ms (30000–3600000), Standard 120000
# BROWSER_USE_TASK_TIMEOUT_MS=120000
